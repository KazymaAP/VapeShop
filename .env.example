# 🔑 VapeShop Environment Variables
# Копируй в .env.local и заполни реальные значения

# ========== TELEGRAM ==========
# Токен бота из @BotFather (https://t.me/botfather)
# Формат: 123456789:ABCDefGhIjKlmnOpqrstuvwxyz
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Secret token для webhook верификации (опционально, для безопасности)
# Генерируется: openssl rand -hex 32
TELEGRAM_BOT_SECRET=your_secret_token_here

# Username бота (без @)
NEXT_PUBLIC_BOT_USERNAME=@your_bot_username

# ========== DATABASE ==========
# PostgreSQL connection string
# Примеры:
# Локальная разработка: postgresql://user:password@localhost:5432/vapeshop
# Neon (production): postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/vapeshop?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/vapeshop

# Альтернативный URL для Neon (если используешь)
NEON_DATABASE_URL=

# ========== TELEGRAM ROLES & ACCESS ==========
# Comma-separated Telegram IDs администраторов (имеют полный доступ)
# Пример: 1656233031,1234567890,9876543210
ADMIN_TELEGRAM_IDS=

# Manager IDs (управление заказами и аналитика)
MANAGER_TELEGRAM_IDS=

# Seller IDs (может добавлять/редактировать товары)
SELLER_TELEGRAM_IDS=

# Support team IDs (ответ на вопросы, рефунды)
SUPPORT_TELEGRAM_IDS=

# Courier IDs (отслеживание доставок)
COURIER_TELEGRAM_IDS=

# ========== SUPABASE (опционально, для хранения изображений) ==========
# URL проекта Supabase (https://app.supabase.com)
SUPABASE_URL=https://xxx.supabase.co

# Anon key для Supabase (public, используется на клиенте)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (приватный, используется на сервере)
SUPABASE_SERVICE_KEY=

# ========== VERCEL DEPLOYMENT ==========
# Автоматически устанавливается на Vercel при деплое
# Для локальной разработки: http://localhost:3000
VERCEL_URL=http://localhost:3000

# Используется для генерации URL и webhook'ов
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3000

# ========== EMAIL (опционально, для уведомлений) ==========
# SMTP сервер для отправки email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Email от которого приходят письма
ADMIN_EMAIL=admin@vapeshop.local

# ========== PAYMENTS (опционально) ==========
# Stripe (если использовать вместо Telegram Stars)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ========== MONITORING & ANALYTICS ==========
# Sentry DSN для отслеживания ошибок (https://sentry.io)
SENTRY_DSN=

# Amplitude API ключ для аналитики (https://app.amplitude.com)
AMPLITUDE_API_KEY=

# ========== DEVELOPMENT & DEBUGGING ==========
# Debug режим (verbose logging): true или false
DEBUG=false

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Используй X-Telegram-Id заголовок для локального тестирования (НЕ production!)
ALLOW_TEST_AUTH=true

# ========== SECURITY TOKENS & SECRETS ==========
# SECRET для защиты CRON задач от несанкционированного доступа
# Генерируется: openssl rand -hex 32
CRON_SECRET=your_cron_secret_token_here_32_chars_minimum

# JWT Secret для токенов сессии
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Secret ключ для HMAC-SHA256 верификации Telegram initData
# Должно совпадать с секретом на клиенте
TELEGRAM_SECRET_KEY=your_telegram_secret_key_here

# ========== RATE LIMITING ==========
# Максимум запросов в минуту (на IP адрес)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ========== FEATURE FLAGS ==========
# Включить реферальную систему (true/false)
ENABLE_REFERRAL=true

# Включить систему гамификации
ENABLE_GAMIFICATION=true

# Включить отслеживание заказов в реальном времени
ENABLE_REAL_TIME_TRACKING=true

# Включить систему поддержки (support tickets)
ENABLE_SUPPORT_SYSTEM=true

# Включить роль курьера для доставок
ENABLE_COURIER_ROLE=true

# Включить платежи через Telegram Stars
ENABLE_TELEGRAM_STARS=true

# ========== IMPORTANT NOTES ==========
# ⚠️ НИКОГДА не коммитай .env.local в Git!
# ✅ Используй .env.example как шаблон
# 🔒 На Vercel переменные хранятся в Settings > Environment Variables
# 📝 Для локальной разработки: скопируй этот файл в .env.local
# 🔐 Все чувствительные данные должны быть в .env.local, никогда не в коде!

# ========== MIGRATION NOTES ==========
# Для запуска миграций БД:
# npm run migrate          # Локальная разработка
# npm run migrate:prod     # Production (Vercel)
