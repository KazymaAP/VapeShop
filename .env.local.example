# 🔑 VapeShop Environment Variables
# Копируй в .env.local и заполни реальные значения

# ========== TELEGRAM ==========
# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# Username бота (без @)
NEXT_PUBLIC_BOT_USERNAME=vapexays_bot

# ========== DATABASE ==========
# PostgreSQL connection string (локальная разработка)
DATABASE_URL=postgresql://postgres:password@localhost:5432/vapeshop

# Neon PostgreSQL (production на Vercel)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/vapeshop

# ========== РОЛИ И ДОСТУП ==========
# Comma-separated Telegram IDs администраторов (имеют полный доступ)
ADMIN_TELEGRAM_IDS=1656233031

# Manager IDs (управление заказами и аналитика)
MANAGER_TELEGRAM_IDS=

# Seller IDs (может добавлять/редактировать товары)
SELLER_TELEGRAM_IDS=

# ========== SUPABASE (опционально, для изображений) ==========
# URL проекта Supabase
SUPABASE_URL=https://xxx.supabase.co

# Anon key для Supabase
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========== VERCEL ==========
# Автоматически устанавливается на Vercel, для локалки:
VERCEL_URL=http://localhost:3000

# ========== OPTIONAL: MONITORING & ANALYTICS ==========
# Sentry DSN для отслеживания ошибок
SENTRY_DSN=

# Amplitude API ключ для аналитики
AMPLITUDE_API_KEY=

# ========== DEVELOPMENT ==========
# Debug режим (verbose logging)
DEBUG=false

# ========== NOTES ==========
# ⚠️ НИКОГДА не коммитай .env.local в Git!
# ✅ Используй .env.local.example как шаблон
# 🔒 На Vercel переменные хранятся в Settings > Environment Variables
# 📝 Для локальной разработки: скопируй этот файл в .env.local
